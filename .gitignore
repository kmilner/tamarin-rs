# Patched Haskell oracle build tree (created by ./setup.sh testing)
/tamarin-prover-testing/

# Scratch worktree used by scripts/bump_submodule.sh while rebasing the patch
/tamarin-prover-rebase/
patches/*.rejected

# Rust build artifacts
/target
target-agent/

# Gate/sweep artifacts — never commit (HS-output caches are GB-scale and
# host-local; result TSVs are per-host measurement snapshots; regenerate
# via scripts/*.sh).  Gate scripts default their RESULTS_TSV into
# scripts/results/; the blanket scripts/*.tsv entry catches strays from
# explicit RESULTS_TSV= runs (tracked files like file_flags.tsv are
# unaffected — gitignore only applies to untracked paths).
scripts/.hs_file_cache*/
scripts/.hs_pretty_cache*/
scripts/.hs_canon_cache/
scripts/.web_hs_cache*/
scripts/.corpus_full_truedl_*.txt
scripts/__pycache__/
scripts/results/
scripts/*.tsv
# scratch workflow scripts dropped by tooling runs
scripts/.wf_*.js

# Probe scratch files
crates/tamarin-theory/examples/probe_*.rs
